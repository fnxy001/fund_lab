# ============================================================================
# fund_lab 环境配置
# ============================================================================
# 使用方法：
#   1. 复制此文件为 .env：  cp .env.example .env
#   2. 修改 .env 中的数据库连接信息
#   3. .env 不会被提交到 git（已在 .gitignore 中）
# ============================================================================

# --- 数据库 ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=fund_lab

# --- 分析参数（通常不需要改）---
RISK_FREE_RATE=0.0
BENCHMARK_NAME=沪深300
DEFAULT_FREQ=W
DAILY_MIN_COVERAGE=0.5
